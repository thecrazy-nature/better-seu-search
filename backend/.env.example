# Optional for local infrastructure, but required for real query planning and
# answer composition. When omitted, the app reports AI unavailable instead of
# generating unreliable rule-based summaries.
#
# DeepSeek is the recommended default for this project.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Generic OpenAI-compatible overrides. These take precedence when set.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# OpenAI fallback compatibility.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI orchestration. With an API key, the default path is:
# AI Query Planner -> FTS/LIKE/BGE local ranking -> single AI Answer Composer -> hard validation.
# AI Reranker / Evidence Judge are optional diagnostics and are off by default for speed.
AI_PLANNER_MODE=always
AI_RERANKER_MODE=off
AI_EVIDENCE_JUDGE_MODE=off
AI_ANSWER_COMPOSER_MODE=simple

# Crawl politeness.
CRAWL_DELAY_SECONDS=1.0
CRAWL_MAX_PAGES_PER_SITE=200
CRAWL_MAX_DEPTH=6
CRAWL_DAYS_BACK=730

# App data location.
SEU_SEARCH_DB=backend/data/seu_search.sqlite3

# Local semantic embedding. BGE is recommended for Chinese semantic retrieval.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_CHARS=2400

# Optional mirror for first-time model download in mainland China.
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ETAG_TIMEOUT=60
HF_HUB_DOWNLOAD_TIMEOUT=60
